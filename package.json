{
  "name": "dv-capture",
  "version": "1.0.0",
  "description": "DV Camcorder Capture Tool",
  "main": "src-electron/main.mjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE ELECTRON_DEV=1 ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.dvcapture.app",
    "productName": "DV Capture",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "files": [
      "dist/**/*",
      "src-electron/**/*"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "vite": "^6.3.5",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "allowScripts": {
    "electron@36.9.5": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}